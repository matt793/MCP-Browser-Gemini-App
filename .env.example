# Gemini API Key
# Copy this file to .env and replace YOUR_API_KEY with your actual Gemini API key.
GEMINI_API_KEY=YOUR_API_KEY

# Optional: Specify the Gemini Model to be used by the agent
# Defaults to gemini-2.5-flash-lite-preview-06-17 if not set
# GEMINI_MODEL="gemini-2.5-flash-lite-preview-06-17"

# Optional: Browser MCP Server Port (if it's configurable or non-default)
# BROWSER_MCP_PORT=61000
